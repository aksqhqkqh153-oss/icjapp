APP_ENV=development
APP_PUBLIC_URL=http://127.0.0.1:8000
API_PUBLIC_URL=http://127.0.0.1:8000
SITE_DOMAIN=www.icj2424app.com
POLICY_URL=https://www.icj2424app.com/privacy-policy
ACCOUNT_DELETION_URL=https://www.icj2424app.com/account-deletion
DATABASE_URL=
SQLITE_DB_PATH=
EMAIL_DEMO_MODE=1
SEED_DEMO_DATA=1
ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:8000,http://localhost:8000,https://www.icj2424app.com,https://icj2424app.com,https://api.icj2424app.com
ALLOWED_ORIGIN_REGEX=https://([a-z0-9-]+\.)*pages\.dev$
LOCAL_UPLOAD_ROOT=
MAX_UPLOAD_MB=20
LOG_LEVEL=INFO

# Settlement sync
SCHEDULE_TIMEZONE=Asia/Seoul
SETTLEMENT_SYNC_ENABLED=1
SETTLEMENT_SYNC_START_HOUR=9
SETTLEMENT_SYNC_END_HOUR=18
SETTLEMENT_SYNC_RANDOM_MIN_MINUTES=30
SETTLEMENT_SYNC_RANDOM_MAX_MINUTES=60
SETTLEMENT_PLAYWRIGHT_HEADLESS=1
SETTLEMENT_PLAYWRIGHT_TIMEOUT_MS=30000
SETTLEMENT_RUNTIME_DIR=
SETTLEMENT_AUTH_STATE_PATH=
SOOMGO_LOGIN_URL=https://soomgo.com/login
SOOMGO_EMAIL=
SOOMGO_PASSWORD=
SOOMGO_VALUE_XPATH=//*[@id="__next"]/main/div/div[2]/div[2]/div[1]/p[1]
SOOMGO_TARGET_URLS=https://soomgo.com/instant-match/65839,https://soomgo.com/instant-match/57259,https://soomgo.com/instant-match/229276

# Railway 대체 키(선택)
SETTLEMENT_SOOMGO_EMAIL=
SETTLEMENT_SOOMGO_PASSWORD=

# Settlement platform sync
SETTLEMENT_SYNC_ENABLED=1
SETTLEMENT_SYNC_START_HOUR=9
SETTLEMENT_SYNC_END_HOUR=18
SETTLEMENT_SYNC_RANDOM_MIN_MINUTES=30
SETTLEMENT_SYNC_RANDOM_MAX_MINUTES=60
SETTLEMENT_PLAYWRIGHT_HEADLESS=1
SETTLEMENT_PLAYWRIGHT_TIMEOUT_MS=30000

# Soomgo
SOOMGO_EMAIL=
SOOMGO_PASSWORD=
SOOMGO_LOGIN_URL=https://soomgo.com/login
SOOMGO_VALUE_XPATH=//*[@id="__next"]/main/div/div[2]/div[2]/div[1]/p[1]
