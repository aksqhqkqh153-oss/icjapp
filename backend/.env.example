APP_ENV=development
APP_PUBLIC_URL=https://api.historyprofile.com
API_PUBLIC_URL=https://api.historyprofile.com
SITE_DOMAIN=www.historyprofile.com
POLICY_URL=https://www.historyprofile.com/privacy-policy
ACCOUNT_DELETION_URL=https://www.historyprofile.com/account-deletion
DATABASE_URL=
SQLITE_DB_PATH=
EMAIL_DEMO_MODE=1
SEED_DEMO_DATA=1
ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:8000,http://localhost:8000,https://www.historyprofile.com,https://historyprofile.com,https://api.historyprofile.com
ALLOWED_ORIGIN_REGEX=https://([a-z0-9-]+\.)*pages\.dev$
LOCAL_UPLOAD_ROOT=
MAX_UPLOAD_MB=50
LOG_LEVEL=INFO

# Settlement sync
SCHEDULE_TIMEZONE=Asia/Seoul
SETTLEMENT_SYNC_ENABLED=1
SETTLEMENT_SYNC_START_HOUR=9
SETTLEMENT_SYNC_END_HOUR=18
SETTLEMENT_SYNC_RANDOM_MIN_MINUTES=30
SETTLEMENT_SYNC_RANDOM_MAX_MINUTES=60
SETTLEMENT_PLAYWRIGHT_HEADLESS=1
SETTLEMENT_PLAYWRIGHT_TIMEOUT_MS=30000
SETTLEMENT_RUNTIME_DIR=
SETTLEMENT_AUTH_STATE_PATH=
SOOMGO_LOGIN_URL=https://soomgo.com/login
SOOMGO_EMAIL=
SOOMGO_PASSWORD=
SOOMGO_VALUE_XPATH=//*[@id="__next"]/main/div/div[2]/div[2]/div[1]/p[1]
SOOMGO_TARGET_URLS=https://soomgo.com/instant-match/65839,https://soomgo.com/instant-match/57259,https://soomgo.com/instant-match/229276

# Railway 대체 키(선택)
SETTLEMENT_SOOMGO_EMAIL=
SETTLEMENT_SOOMGO_PASSWORD=

# Settlement platform sync
SETTLEMENT_SYNC_ENABLED=1
SETTLEMENT_SYNC_START_HOUR=9
SETTLEMENT_SYNC_END_HOUR=18
SETTLEMENT_SYNC_RANDOM_MIN_MINUTES=30
SETTLEMENT_SYNC_RANDOM_MAX_MINUTES=60
SETTLEMENT_PLAYWRIGHT_HEADLESS=1
SETTLEMENT_PLAYWRIGHT_TIMEOUT_MS=30000

# Soomgo
SOOMGO_EMAIL=
SOOMGO_PASSWORD=
SOOMGO_LOGIN_URL=https://soomgo.com/login
SOOMGO_VALUE_XPATH=//*[@id="__next"]/main/div/div[2]/div[2]/div[1]/p[1]
SOOMGO_TARGET_URLS=https://soomgo.com/instant-match/65839,https://soomgo.com/instant-match/57259,https://soomgo.com/instant-match/229276

# Ohou / 오늘의집
OHOU_EMAIL=
OHOU_PASSWORD=
OHOU_LOGIN_URL=https://o2o-partner.ohou.se/moving/payment/cash
OHOU_TARGET_URL=https://o2o-partner.ohou.se/moving/payment/cash
OHOU_CONTAINER_XPATH=//*[@id="__next"]/div[1]/main/div[2]/section/div[2]/div/div[2]
OHOU_SECTION_XPATH=//*[@id="__next"]/div[1]/main/div[2]/section/div[2]/div/div[2]/section
OHOU_ACCEPT_KEYWORD=오더 수락

TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

TURNSTILE_ALLOWED_HOSTNAMES=127.0.0.1,localhost,www.historyprofile.com,historyprofile.com,api.historyprofile.com

# Turnstile hostnames must match your real deploy domains

# 서버 비용/봇 접근 보호
COST_PROTECTION_ENABLED=1
IP_RATE_LIMIT_WINDOW_SECONDS=60
IP_RATE_LIMIT_REQUESTS=240
AUTH_RATE_LIMIT_WINDOW_SECONDS=600
AUTH_RATE_LIMIT_REQUESTS=30
PUBLIC_PAGE_RATE_LIMIT_WINDOW_SECONDS=60
PUBLIC_PAGE_RATE_LIMIT_REQUESTS=90
API_READ_RATE_LIMIT_WINDOW_SECONDS=60
API_READ_RATE_LIMIT_REQUESTS=120
BOT_BLOCK_USER_AGENTS=python-requests,curl/,wget,scrapy,aiohttp,httpx,selenium,playwright,phantomjs,headlesschrome,java/
