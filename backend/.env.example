# Ohou / 오늘의집
OHOU_EMAIL=
OHOU_PASSWORD=
OHOU_LOGIN_URL=https://o2o-partner.ohou.se/moving/payment/cash
OHOU_TARGET_URL=https://o2o-partner.ohou.se/moving/payment/cash
OHOU_CONTAINER_XPATH=//*[@id="__next"]/div[1]/main/div[2]/section/div[2]/div/div[2]
OHOU_SECTION_XPATH=//*[@id="__next"]/div[1]/main/div[2]/section/div[2]/div/div[2]/section
