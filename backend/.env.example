# Optional route travel-time providers
# KAKAO_REST_API_KEY: Kakao Local(주소검색) + Kakao Mobility(길찾기) 겸용 REST 키
KAKAO_REST_API_KEY=
# KAKAO_MOBILITY_REST_API_KEY: 위 키와 별도로 운영할 때만 사용
KAKAO_MOBILITY_REST_API_KEY=
NAVER_MAPS_CLIENT_ID=
NAVER_MAPS_CLIENT_SECRET=
# NAVER_MAPS_KEY_ID / NAVER_MAPS_KEY: 네이버 콘솔에서 표기되는 대체 변수명도 함께 지원
NAVER_MAPS_KEY_ID=
NAVER_MAPS_KEY=
